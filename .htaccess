# Protect includes directory from direct web access
RewriteEngine On
RewriteRule ^includes/.*$ - [F,L]
RewriteRule ^sql/.*$ - [F,L]

# Default to index.php
DirectoryIndex index.php

# Disable directory listings
Options -Indexes

# HTTPS redirect is handled by cPanel's "Force HTTPS Redirect" toggle on
# the Domains page — not from .htaccess. Hostgator's reverse-proxy setup
# means %{HTTPS} / %{SERVER_PORT} / X-Forwarded-Proto are unreliable here.

# Basic security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
